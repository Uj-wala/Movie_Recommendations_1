OMDB_API_KEY=your_api_key_here
OMDB_API_URL=https://www.omdbapi.com
BACKEND_SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:5173
# MySQL Workbench/local MySQL database. Replace root and your_mysql_password if your local MySQL user is different.
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/movie_recommendation?charset=utf8mb4
# Comma-separated deployed frontend URLs allowed by CORS.
# Example: FRONTEND_ORIGINS=https://your-site.netlify.app,https://www.yourdomain.com
FRONTEND_ORIGINS=http://localhost:5173

# Gmail SMTP for reset-password verification codes.
# Replace SMTP_USERNAME, SMTP_PASSWORD, and SMTP_FROM_EMAIL with a Gmail account
# and a Google App Password. Do not use your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ujwalaramana09@gmail.com
SMTP_PASSWORD=your-16-character-google-app-password
SMTP_FROM_EMAIL=ujwalaramana09@gmail.com
SMTP_USE_TLS=true

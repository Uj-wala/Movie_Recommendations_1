OMDB_API_KEY=your_api_key_here
OMDB_API_URL=https://www.omdbapi.com
BACKEND_SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
BCRYPT_ROUNDS=10
FRONTEND_URL=http://localhost:5173
# SQLite fallback:
# DATABASE_URL=sqlite:///./movies.db
# MySQL Workbench/local MySQL database:
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/movie_recommendation?charset=utf8mb4
# Comma-separated deployed frontend URLs allowed by CORS.
# Example: FRONTEND_ORIGINS=https://your-site.netlify.app,https://www.yourdomain.com
FRONTEND_ORIGINS=http://localhost:5173

# Gmail SMTP for reset-password verification codes.
# Use a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-character-google-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_USE_TLS=true
